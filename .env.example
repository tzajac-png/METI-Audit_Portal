# Required for audit login (choose a strong password)
AUDIT_PASSWORD=change-me

# Required for main course portal (/ and /courses). Set in .env.local (not committed).
DASHBOARD_PASSWORD=change-me

# Required: at least 16 characters, used to sign session cookies
AUDIT_SECRET=replace-with-a-long-random-string

# Vercel Blob (instructor document uploads on serverless — enable Storage → Blob
# on the project; Vercel injects this automatically when linked, or paste token)
# BLOB_READ_WRITE_TOKEN=

# Required for sheet-backed pages: Google Cloud API key with “Google Sheets API”
# enabled. The app reads tabs via the Sheets API so hidden rows/columns match
# the sheet. Public CSV cannot represent visibility.
# GOOGLE_SHEETS_API_KEY=

# Dev-only: allow CSV export when no API key is set (hidden rows/columns may
# still appear — not for production).
# GOOGLE_SHEETS_ALLOW_CSV_FALLBACK=true

# Optional: column name (exact or case-insensitive match) — when TRUE/Yes/1/X/etc., that course row is excluded from portal + audit lists (in addition to rows hidden via the Sheets UI when using GOOGLE_SHEETS_API_KEY).
# GOOGLE_SHEET_HIDE_COURSE_COLUMN=Hidden

# Optional spreadsheet overrides (same workbook by default)
# GOOGLE_SHEET_ID=1J9OO6YGdwnArcVn_K8CUHQHwOiIAeQj2vZcpyIbWWTE
# BLS Student signups (match students to course code)
# GOOGLE_SHEET_GID_STUDENTS=854682937
# Program-specific student tabs (defaults match Student Sign Up 2026)
# GOOGLE_SHEET_GID_ACLS_STUDENTS=907531989
# GOOGLE_SHEET_GID_PALS_STUDENTS=504976157
# GOOGLE_SHEET_GID_HEARTSAVER_STUDENTS=1663755098
# Student Master / directory (all students)
# GOOGLE_SHEET_GID_STUDENT_DIRECTORY=590953723
# Instructor directory (person roster — same workbook, Instructor roster tab)
# GOOGLE_SHEET_GID_INSTRUCTOR_DIRECTORY=482270132
# Instructor document Google Form responses (Document Type, Upload Document link, etc.)
# GOOGLE_SHEET_GID_INSTRUCTOR_UPLOAD_FORM=1991989031
# Instructor tabs (Student Sign Up 2026 workbook) — defaults match METI sheet tabs
# GOOGLE_SHEET_GID_BLS_INSTRUCTOR=89421864
# GOOGLE_SHEET_GID_ACLS_INSTRUCTOR=190493285
# GOOGLE_SHEET_GID_PALS_INSTRUCTOR=547470971
# GOOGLE_SHEET_GID_HEARTSAVER_INSTRUCTOR=1227957035
